                contact.Id.HasValue && LoadedContactIds.Contains(contact.Id.Value) ? contact.Id : null,
                contact.FullName ?? string.Empty,
                contact.Relationship ?? string.Empty,
                contact.Job ?? string.Empty,
                contact.Address ?? string.Empty,
                contact.PhoneNumber ?? string.Empty,
                contact.MobileNumber ?? string.Empty,
                contact.IsPrimary,
                contact.IsEmergencyContact,
                contact.Notes ?? string.Empty)).ToList(),
            MedicalConditions = Form.MedicalConditions.Select(condition => new ResidentMedicalConditionEditorDto(
                condition.Id.HasValue && LoadedConditionIds.Contains(condition.Id.Value) ? condition.Id : null,
                condition.ConditionCode,
                condition.ConditionName,
                condition.HasCondition,
                condition.Notes ?? string.Empty)).ToList()
        };
    }

    private void InitializeEditContext()
    {
        EditContext = new EditContext(Form);
        ValidationMessages = new ValidationMessageStore(EditContext);
        EditContext.OnFieldChanged += (_, args) =>
        {
            ValidationMessages.Clear(args.FieldIdentifier);
            EditContext.NotifyValidationStateChanged();
        };
    }

    private bool ValidateForm()
    {
        ValidationMessages.Clear();
        EnsureContactRows();

        var issues = ResidentUpsertBusinessRules.Validate(BuildDto());
        if (issues.Count == 0)
        {
            EditContext.NotifyValidationStateChanged();
            return true;
        }

        ActiveTab = ResolveTab(issues[0].Field);

        foreach (var issue in issues)
        {
            AddIssueMessages(issue);
        }

        EditContext.NotifyValidationStateChanged();
        return false;
    }

    private void AddIssueMessages(ResidentValidationIssue issue)
    {
        var message = LocalizeIssue(issue);

        switch (issue.Field)
        {
            case nameof(ResidentUpsertDto.Code):
                AddValidationMessage(() => Form.Code, message);
                break;
            case nameof(ResidentUpsertDto.FullName):
                AddValidationMessage(() => Form.FullName, message);
                break;
            case nameof(ResidentUpsertDto.BirthDate):
                AddValidationMessage(() => Form.BirthDate, message);
                break;
            case nameof(ResidentUpsertDto.Gender):
                AddValidationMessage(() => Form.Gender, message);
                break;
            case nameof(ResidentUpsertDto.CurrentAddress):
                AddValidationMessage(() => Form.CurrentAddress, message);
                break;
            case "IdentityDocument":
                AddValidationMessage(() => Form.NationalId, message);
                AddValidationMessage(() => Form.PassportNumber, message);
                break;
            case nameof(ResidentUpsertDto.AdmissionDate):
                AddValidationMessage(() => Form.AdmissionDate, message);
                break;
            case nameof(ResidentUpsertDto.RoomId):
                AddValidationMessage(() => Form.RoomId, message);
                break;
            case "Contacts":
            case "PrimaryContactFullName":
                AddValidationMessage(() => Form.Contacts[PrimaryContactIndex()].FullName, message);
                break;
            case "PrimaryContactRelationship":
                AddValidationMessage(() => Form.Contacts[PrimaryContactIndex()].Relationship, message);
                break;
            case "PrimaryContactPhone":
                AddValidationMessage(() => Form.Contacts[PrimaryContactIndex()].PhoneNumber, message);
                AddValidationMessage(() => Form.Contacts[PrimaryContactIndex()].MobileNumber, message);
                break;
        }
    }

    private void AddValidationMessage<TField>(Expression<Func<TField>> accessor, string message)
    {
        ValidationMessages.Add(FieldIdentifier.Create(accessor), message);
    }

    private string LocalizeIssue(ResidentValidationIssue issue)
    {
        var localized = R[issue.MessageKey];
        return localized.ResourceNotFound ? issue.DefaultMessage : localized.Value;
    }

    private int PrimaryContactIndex()
    {
        EnsureContactRows();
        var index = Form.Contacts.FindIndex(contact => contact.IsPrimary);
        return index >= 0 ? index : 0;
    }

    private string ResolveTab(string field) => field switch
    {
        nameof(ResidentUpsertDto.Code) or
        nameof(ResidentUpsertDto.FullName) or
        nameof(ResidentUpsertDto.BirthDate) or
        nameof(ResidentUpsertDto.Gender) or
        nameof(ResidentUpsertDto.CurrentAddress) or
        "IdentityDocument" => "basic",
        nameof(ResidentUpsertDto.AdmissionDate) or
        nameof(ResidentUpsertDto.RoomId) => "admission",
        "Contacts" or
        "PrimaryContactFullName" or
        "PrimaryContactRelationship" or
        "PrimaryContactPhone" => "contacts",
        _ => ActiveTab
    };

    private string InputClass<TField>(Expression<Func<TField>> accessor)
    {
        var hasErrors = EditContext.GetValidationMessages(FieldIdentifier.Create(accessor)).Any();
        return hasErrors ? "input input-invalid" : "input";
    }

    private string SelectClass<TField>(Expression<Func<TField>> accessor)
    {
        var hasErrors = EditContext.GetValidationMessages(FieldIdentifier.Create(accessor)).Any();
        return hasErrors ? "select input-invalid" : "select";
    }

    private static string ReadableToken(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return string.Concat(value.Select((ch, index) => index > 0 && char.IsUpper(ch) ? $" {ch}" : ch.ToString()));
    }

