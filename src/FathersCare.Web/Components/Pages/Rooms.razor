@page "/rooms"
@rendermode InteractiveServer
@implements IAsyncDisposable
@using System.ComponentModel.DataAnnotations
@using FathersCare.Application.Abstractions
@using FathersCare.Application.Rooms.Commands.AssignResidentToRoom
@using FathersCare.Application.Rooms.Commands.CompleteRoomMaintenanceRequest
@using FathersCare.Application.Rooms.Commands.CreateFloor
@using FathersCare.Application.Rooms.Commands.CreateRoom
@using FathersCare.Application.Rooms.Commands.CreateRoomMaintenanceRequest
@using FathersCare.Application.Rooms.Commands.DeleteRoom
@using FathersCare.Application.Rooms.Commands.UpdateRoomCapacity
@inject IRoomManagementService RoomService
@inject ICommandHandler<CreateFloorCommand, Guid> CreateFloorHandler
@inject ICommandHandler<CreateRoomCommand, Guid> CreateRoomHandler
@inject ICommandHandler<UpdateRoomCapacityCommand, bool> UpdateRoomCapacityHandler
@inject ICommandHandler<DeleteRoomCommand, bool> DeleteRoomHandler
@inject ICommandHandler<AssignResidentToRoomCommand, bool> AssignResidentToRoomHandler
@inject ICommandHandler<CreateRoomMaintenanceRequestCommand, Guid> CreateRoomMaintenanceRequestHandler
@inject ICommandHandler<CompleteRoomMaintenanceRequestCommand, bool> CompleteRoomMaintenanceRequestHandler

<PageTitle>إدارة الغرف والأدوار والصيانة</PageTitle>

<HeadContent>
    <link rel="stylesheet" href="/css/fathers-rooms.css" />
</HeadContent>

@if (Model is null)
{
    <div class="fc-rooms-loading-card">
        <div class="fc-rooms-spinner"></div>
        <strong>جاري تحميل بيانات الغرف...</strong>
        <span>يتم تجهيز خريطة الإشغال والصيانة.</span>
    </div>
}
else
{
    <div class="fc-rooms-page fc-rooms-page-wide">
        <section class="fc-rooms-header">
            <div class="fc-rooms-title-block">
                <span class="fc-rooms-breadcrumb">الرئيسية / الغرف والأدوار</span>
                <h1>إدارة الغرف والأدوار</h1>
                <p>خريطة تشغيلية واضحة للغرف، الإشغال، الأسرة المتاحة، وطلبات الصيانة المفتوحة.</p>
            </div>

            <div class="fc-rooms-header-actions">
                <a class="fc-rooms-btn fc-rooms-btn-light" href="residents">النزلاء</a>
                <button class="fc-rooms-btn fc-rooms-btn-light" type="button" @onclick="Load">تحديث</button>
                <button class="fc-rooms-btn fc-rooms-btn-primary" type="button">@DateTime.Today.ToString("dd / MM / yyyy")</button>
                <span class="fc-rooms-live-pill">تحديث تلقائي كل 3 ثواني</span>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="fc-rooms-message @(MessageIsError ? "fc-rooms-message-error" : "fc-rooms-message-success")">
                <span>@(MessageIsError ? "!" : "✓")</span>
                <p>@Message</p>
            </div>
        }

        <section class="fc-rooms-summary-grid">
            <div class="fc-rooms-summary-card is-info">
                <div class="fc-rooms-summary-icon">د</div>
                <span>الأدوار</span>
                <strong>@Model.TotalFloors</strong>
                <small>مستويات تشغيل</small>
            </div>
            <div class="fc-rooms-summary-card is-info">
                <div class="fc-rooms-summary-icon">غ</div>
                <span>الغرف</span>
                <strong>@Model.TotalRooms</strong>
                <small>غرف قابلة للتسكين</small>
            </div>
            <div class="fc-rooms-summary-card is-safe">
                <div class="fc-rooms-summary-icon">س</div>
                <span>الأسرة المتاحة</span>
                <strong>@Model.AvailableBeds</strong>
                <small>@Model.OccupiedBeds من @Model.TotalBeds مشغول</small>
            </div>
            <div class="fc-rooms-summary-card @(Model.FullRooms > 0 ? "is-warning" : "is-safe")">
                <div class="fc-rooms-summary-icon">م</div>
                <span>غرف مكتملة</span>
                <strong>@Model.FullRooms</strong>
                <small>لا تستقبل نزلاء جدد</small>
            </div>
            <div class="fc-rooms-summary-card @(Model.OpenMaintenanceRequests > 0 ? "is-warning" : "is-safe")">
                <div class="fc-rooms-summary-icon">ص</div>
                <span>صيانة مفتوحة</span>
                <strong>@Model.OpenMaintenanceRequests</strong>
                <small>تحتاج متابعة</small>
            </div>
            <div class="fc-rooms-summary-card @(Model.UrgentMaintenanceRequests > 0 ? "is-danger" : "is-safe")">
                <div class="fc-rooms-summary-icon">!</div>
                <span>صيانة عالية</span>
                <strong>@Model.UrgentMaintenanceRequests</strong>
                <small>أولوية تنفيذ</small>
            </div>
        </section>

        <section class="fc-rooms-top-grid fc-rooms-top-grid-wide">
            <article class="fc-rooms-card fc-rooms-overview-card">
                <div class="fc-rooms-card-header">
                    <div>
                        <h2>ملخص الإشغال</h2>
                        <p>مؤشرات سريعة قبل مراجعة تفاصيل كل غرفة.</p>
                    </div>
                    <span class="fc-rooms-counter">@Model.TotalBeds سرير</span>
                </div>
                <div class="fc-rooms-overview-list">
                    <div class="fc-rooms-overview-row is-safe">
                        <span>أسرة متاحة</span>
                        <strong>@Model.AvailableBeds</strong>
                    </div>
                    <div class="fc-rooms-overview-row is-info">
                        <span>أسرة مشغولة</span>
                        <strong>@Model.OccupiedBeds</strong>
                    </div>
                    <div class="fc-rooms-overview-row @(Model.FullRooms > 0 ? "is-warning" : "is-safe")">
                        <span>غرف مكتملة</span>
                        <strong>@Model.FullRooms</strong>
                    </div>
                    <div class="fc-rooms-overview-row @(Model.UrgentMaintenanceRequests > 0 ? "is-danger" : "is-safe")">
                        <span>صيانة عاجلة</span>
                        <strong>@Model.UrgentMaintenanceRequests</strong>
                    </div>
                </div>
            </article>

            <article class="fc-rooms-card fc-rooms-quick-card">
                <div class="fc-rooms-card-header">
                    <div>
                        <h2>إجراءات سريعة</h2>
                        <p>كل الإجراءات الرئيسية تفتح داخل نافذة منبثقة.</p>
                    </div>
                </div>
                <div class="fc-rooms-action-grid">
                    <button type="button" @onclick='() => OpenPopup("floor")'>إضافة دور</button>
                    <button type="button" @onclick='() => OpenPopup("room")'>إضافة غرفة</button>
                    <button type="button" @onclick='() => OpenPopup("assign")'>تسكين نزيل</button>
                    <button type="button" @onclick='() => OpenPopup("maintenance")'>طلب صيانة</button>
                </div>
            </article>

            <article class="fc-rooms-card fc-rooms-alert-card">
                <div class="fc-rooms-card-header">
                    <div>
                        <h2>تنبيهات الغرف</h2>
                        <p>أهم الحالات التي تحتاج متابعة.</p>
                    </div>
                    <span class="fc-rooms-counter">@(Model.OpenMaintenanceRequests + Model.UrgentMaintenanceRequests + Model.FullRooms)</span>
                </div>
                <div class="fc-rooms-overview-list">
                    <div class="fc-rooms-overview-row @(Model.OpenMaintenanceRequests > 0 ? "is-warning" : "is-safe")"><span>طلبات صيانة مفتوحة</span><strong>@Model.OpenMaintenanceRequests</strong></div>
                    <div class="fc-rooms-overview-row @(Model.UrgentMaintenanceRequests > 0 ? "is-danger" : "is-safe")"><span>طلبات عالية الأولوية</span><strong>@Model.UrgentMaintenanceRequests</strong></div>
                    <div class="fc-rooms-overview-row @(Model.FullRooms > 0 ? "is-warning" : "is-safe")"><span>غرف مكتملة</span><strong>@Model.FullRooms</strong></div>
                </div>
            </article>
        </section>

        <section class="fc-rooms-main-grid full-span-grid">
            <main class="fc-rooms-card fc-rooms-map-card">
                <div class="fc-rooms-map-toolbar">
                    <div>
                        <h2>خريطة الإشغال</h2>
                        <p>كل غرفة مرتبطة بالنزلاء الحاليين وحالة الصيانة.</p>
                    </div>
                    <select class="select" @bind="SelectedFloorId" @bind:after="Load">
                        <option value="">كل الأدوار</option>
                        @foreach (var floor in Model.Floors)
                        {
                            <option value="@floor.Id">@floor.Name</option>
                        }
                    </select>
                </div>

                @if (Model.FloorSections.Count == 0)
                {
                    <div class="fc-rooms-empty">لا توجد غرف مسجلة لهذا الاختيار.</div>
                }
                else
                {
                    <div class="fc-rooms-floor-stack">
                        @foreach (var floor in Model.FloorSections)
                        {
                            <section class="fc-rooms-floor-section">
                                <div class="fc-rooms-floor-heading">
                                    <div>
                                        <h3>@floor.Name</h3>
                                        <p>@floor.Occupied من @floor.Capacity سرير مشغول</p>
                                    </div>
                                    <span>@floor.Rooms.Count غرفة</span>
                                </div>

                                <div class="fc-rooms-card-grid">
                                    @foreach (var room in floor.Rooms)
                                    {
                                        <article class="fc-room-card @room.State @room.MaintenanceState">
                                            <div class="fc-room-card-top">
                                                <div>
                                                    <span>غرفة</span>
                                                    <strong>@room.Number</strong>
                                                </div>
                                                <span class="fc-room-status @room.State @room.MaintenanceState">@RoomStatusText(room)</span>
                                            </div>

                                            <div class="fc-room-meter" style="@($"--room-fill:{RoomFill(room)}%")">
                                                <span></span>
                                            </div>

                                            <div class="fc-room-meta">
                                                <span>@room.OccupancyText مشغول</span>
                                                <span>@room.AvailableBeds سرير متاح</span>
                                            </div>

                                            <div class="fc-room-residents">
                                                @if (room.Residents.Count == 0)
                                                {
                                                    <span class="fc-room-empty-chip">لا يوجد نزيل</span>
                                                }
                                                else
                                                {
                                                    @foreach (var resident in room.Residents)
                                                    {
                                                        <a class="fc-room-resident" href="residents/@resident.Id">
                                                            @if (!string.IsNullOrWhiteSpace(resident.PhotoPath))
                                                            {
                                                                <img src="@resident.PhotoPath" alt="@resident.Name" />
                                                            }
                                                            else
                                                            {
                                                                <span>@resident.Name.FirstOrDefault()</span>
                                                            }
                                                            <strong>@resident.Name</strong>
                                                        </a>
                                                    }
                                                }
                                            </div>

                                            <div class="fc-room-maintenance @room.MaintenanceState">
                                                @MaintenanceStateText(room.MaintenanceState)
                                            </div>

                                            @if (room.DelayedMedicationCount > 0)
                                            {
                                                <div class="fc-room-medication-alert">
                                                    علاج متأخر (@room.DelayedMedicationCount)
                                                </div>
                                            }

                                            <div class="fc-room-card-actions">
                                                <button class="fc-rooms-mini-btn" type="button" @onclick="() => OpenRoomManagement(room)">إدارة</button>
                                            </div>
                                        </article>
                                    }
                                </div>
                            </section>
                        }
                    </div>
                }
            </main>
        </section>

        <section class="fc-maintenance-grid full-span-grid">
            <div class="fc-rooms-card fc-maintenance-board full-board">
                <div class="fc-rooms-card-header">
                    <div>
                        <h2>طلبات الصيانة المفتوحة</h2>
                        <p>إغلاق الطلب يتم بعد التنفيذ الفعلي فقط.</p>
                    </div>
                    <div class="fc-rooms-board-actions">
                        <span class="fc-rooms-counter">@Model.MaintenanceRequests.Count</span>
                        <button class="fc-rooms-mini-btn primary" type="button" @onclick='() => OpenPopup("maintenance")'>طلب صيانة جديد</button>
                    </div>
                </div>
                <div class="fc-rooms-table-scroll">
                    <table class="fc-rooms-table">
                        <thead>
                            <tr>
                                <th>الغرفة</th>
                                <th>النزيل</th>
                                <th>البلاغ</th>
                                <th>الأولوية</th>
                                <th>المسؤول</th>
                                <th>التاريخ</th>
                                <th>تنفيذ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var request in Model.MaintenanceRequests)
                            {
                                <tr>
                                    <td><strong>@request.Room</strong><span class="fc-cell-subtitle">@request.Floor</span></td>
                                    <td>@request.Resident</td>
                                    <td><strong>@request.Title</strong><span class="fc-cell-subtitle">@request.Description</span></td>
                                    <td><span class="fc-room-status @request.PriorityState">@PriorityText(request.Priority)</span></td>
                                    <td>@request.AssignedTo</td>
                                    <td>@request.ReportedAt</td>
                                    <td><button class="fc-rooms-mini-btn primary" type="button" disabled="@IsBusy" @onclick="() => OpenCompleteMaintenancePopup(request.Id, request.Title)">تم التنفيذ</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        @if (ActivePopup is not null)
        {
            <div class="fc-room-modal-backdrop" role="presentation" @onclick="ClosePopup">
                <section class="fc-room-management-modal fc-room-popup-modal" role="dialog" aria-modal="true" @onclick:stopPropagation="true">
                    <div class="fc-room-modal-header">
                        <div>
                            <h2>@PopupTitle</h2>
                            <p>@PopupSubtitle</p>
                        </div>
                        <button class="fc-rooms-mini-btn" type="button" aria-label="إغلاق" @onclick="ClosePopup">×</button>
                    </div>

                    @if (ActivePopup == "floor")
                    {
                        <div class="fc-room-form-card">
                            <div class="fc-rooms-form-grid one-col">
                                <label class="fc-rooms-field"><span>اسم الدور</span><input class="input" required @bind="NewFloor.Name" /></label>
                                <label class="fc-rooms-field"><span>رقم الدور</span><input class="input" type="number" min="1" required @bind="NewFloor.Number" /></label>
                            </div>
                            <div class="fc-room-management-actions">
                                <button class="fc-rooms-btn fc-rooms-btn-primary" type="button" disabled="@IsBusy" @onclick="CreateFloorAsync">حفظ الدور</button>
                            </div>
                            @PanelMessage("floor")
                        </div>
                    }
                    else if (ActivePopup == "room")
                    {
                        <div class="fc-room-form-card">
                            <div class="fc-rooms-form-grid one-col">
                                <label class="fc-rooms-field">
                                    <span>الدور</span>
                                    <select class="select" required @bind="NewRoom.FloorId">
                                        <option value="@Guid.Empty">اختر الدور</option>
                                        @foreach (var floor in Model.Floors)
                                        {
                                            <option value="@floor.Id">@floor.Name</option>
                                        }
                                    </select>
                                </label>
                                <label class="fc-rooms-field"><span>رقم الغرفة</span><input class="input" required @bind="NewRoom.Number" /></label>
                                <label class="fc-rooms-field"><span>السعة</span><input class="input" type="number" min="1" max="8" required @bind="NewRoom.Capacity" /></label>
                            </div>
                            <div class="fc-room-management-actions">
                                <button class="fc-rooms-btn fc-rooms-btn-primary" type="button" disabled="@IsBusy" @onclick="CreateRoomAsync">حفظ الغرفة</button>
                            </div>
                            @PanelMessage("room")
                        </div>
                    }
                    else if (ActivePopup == "assign")
                    {
                        <div class="fc-room-form-card">
                            <div class="fc-rooms-form-grid one-col">
                                <label class="fc-rooms-field">
                                    <span>النزيل</span>
                                    <select class="select" required @bind="Assignment.ResidentId">
                                        <option value="@Guid.Empty">اختر النزيل</option>
                                        @foreach (var resident in Model.ResidentOptions)
                                        {
                                            <option value="@resident.Id">@resident.Name</option>
                                        }
                                    </select>
                                </label>
                                <label class="fc-rooms-field">
                                    <span>الغرفة</span>
                                    <select class="select" required @bind="Assignment.RoomId">
                                        <option value="@Guid.Empty">اختر الغرفة</option>
                                        @foreach (var room in Model.RoomOptions)
                                        {
                                            <option value="@room.Id">@room.Label</option>
                                        }
                                    </select>
                                </label>
                            </div>
                            <div class="fc-room-management-actions">
                                <button class="fc-rooms-btn fc-rooms-btn-primary" type="button" disabled="@IsBusy" @onclick="AssignResidentAsync">تأكيد التسكين</button>
                            </div>
                            @PanelMessage("assign")
                        </div>
                    }
                    else if (ActivePopup == "maintenance")
                    {
                        <div class="fc-room-form-card">
                            <div class="fc-rooms-form-grid">
                                <label class="fc-rooms-field">
                                    <span>الغرفة</span>
                                    <select class="select" required @bind="Maintenance.RoomId">
                                        <option value="@Guid.Empty">اختر الغرفة</option>
                                        @foreach (var room in Model.RoomOptions)
                                        {
                                            <option value="@room.Id">@room.Label</option>
                                        }
                                    </select>
                                </label>
                                <label class="fc-rooms-field">
                                    <span>النزيل المرتبط</span>
                                    <select class="select" @bind="MaintenanceResidentValue">
                                        <option value="">بدون نزيل محدد</option>
                                        @foreach (var resident in Model.ResidentOptions)
                                        {
                                            <option value="@resident.Id">@resident.Name</option>
                                        }
                                    </select>
                                </label>
                                <label class="fc-rooms-field"><span>عنوان البلاغ</span><input class="input" required @bind="Maintenance.Title" /></label>
                                <label class="fc-rooms-field">
                                    <span>الأولوية</span>
                                    <select class="select" required @bind="Maintenance.Priority">
                                        <option value="Low">منخفضة</option>
                                        <option value="Normal">متوسطة</option>
                                        <option value="High">عالية</option>
                                        <option value="Urgent">عاجلة</option>
                                    </select>
                                </label>
                                <label class="fc-rooms-field"><span>المبلغ</span><input class="input" required @bind="Maintenance.ReportedBy" /></label>
                                <label class="fc-rooms-field"><span>المسؤول عن التنفيذ</span><input class="input" @bind="Maintenance.AssignedTo" /></label>
                                <label class="fc-rooms-field fc-rooms-field-wide"><span>الوصف</span><textarea class="input textarea" required @bind="Maintenance.Description"></textarea></label>
                            </div>
                            <div class="fc-room-management-actions">
                                <button class="fc-rooms-btn fc-rooms-btn-primary" type="button" disabled="@IsBusy" @onclick="CreateMaintenanceAsync">حفظ طلب الصيانة</button>
                            </div>
                            @PanelMessage("maintenance")
                        </div>
                    }
                    else if (ActivePopup == "complete-maintenance")
                    {
                        <div class="fc-room-form-card fc-confirmation-card">
                            <p class="fc-confirmation-text">هل تريد تأكيد إغلاق طلب الصيانة <strong>@PendingMaintenanceTitle</strong>؟</p>
                            <div class="fc-room-management-actions">
                                <button class="fc-rooms-btn fc-rooms-btn-primary" type="button" disabled="@IsBusy" @onclick="ConfirmCompleteMaintenanceAsync">تأكيد التنفيذ</button>
                                <button class="fc-rooms-btn fc-rooms-btn-light" type="button" @onclick="ClosePopup">إلغاء</button>
                            </div>
                            @PanelMessage("maintenance")
                        </div>
                    }
                </section>
            </div>
        }

        @if (IsRoomManagementOpen)
        {
            <div class="fc-room-modal-backdrop" role="presentation" @onclick="CloseRoomManagement">
                <section class="fc-room-management-modal" role="dialog" aria-modal="true" aria-labelledby="room-management-title" @onclick:stopPropagation="true">
                    <div class="fc-room-modal-header">
                        <div>
                            <h2 id="room-management-title">إدارة غرفة</h2>
                            <p>تعديل عدد الأسرة أو حذف الغرفة إذا كانت خالية تماما.</p>
                        </div>
                        <button class="fc-rooms-mini-btn" type="button" aria-label="إغلاق" @onclick="CloseRoomManagement">×</button>
                    </div>

                    <div class="fc-room-form-card">
                        <label class="fc-rooms-field">
                            <span>الغرفة</span>
                            <select class="select" required @bind="ManagedRoom.RoomId" @bind:after="SyncManagedRoomCapacity">
                                <option value="@Guid.Empty">اختر الغرفة</option>
                                @foreach (var room in Model.RoomOptions)
                                {
                                    <option value="@room.Id">@room.Label</option>
                                }
                            </select>
                        </label>
                        <label class="fc-rooms-field"><span>عدد الأسرة</span><input class="input" type="number" min="1" max="8" required @bind="ManagedRoom.Capacity" /></label>
                        <div class="fc-room-management-actions">
                            <button class="fc-rooms-btn fc-rooms-btn-primary" type="button" disabled="@IsBusy" @onclick="UpdateRoomCapacityAsync">تعديل السعة</button>
                            <button class="fc-rooms-btn fc-rooms-btn-danger" type="button" disabled="@(IsBusy || !CanDeleteManagedRoom)" @onclick="DeleteRoomAsync">حذف الغرفة</button>
                        </div>
                        <small class="fc-room-rule-note">الحذف يتم Soft Delete، ومتاح فقط لو الغرفة بدون نزلاء وبدون صيانة مفتوحة.</small>
                        @PanelMessage("manage")
                    </div>
                </section>
            </div>
        }
    </div>
}

@code {
    private RoomsWorkspaceViewModel? Model;
    private string? Message;
    private bool MessageIsError;
    private bool IsBusy;
    private bool IsAutoRefreshing;
    private bool IsRoomManagementOpen;
    private string? ActivePopup;
    private Guid? PendingMaintenanceRequestId;
    private string PendingMaintenanceTitle = string.Empty;
    private CancellationTokenSource? AutoRefreshCts;
    private string LastActionArea = string.Empty;
    private Guid? SelectedFloorId;
    private FloorForm NewFloor { get; set; } = new();
    private RoomForm NewRoom { get; set; } = new();
    private ManagedRoomForm ManagedRoom { get; set; } = new();
    private AssignmentForm Assignment { get; set; } = new();
    private MaintenanceForm Maintenance { get; set; } = new() { Priority = "Normal", ReportedBy = "إدارة الدار" };

    private string MaintenanceResidentValue
    {
        get => Maintenance.ResidentId?.ToString() ?? string.Empty;
        set => Maintenance.ResidentId = Guid.TryParse(value, out var id) ? id : null;
    }

    private string PopupTitle => ActivePopup switch
    {
        "floor" => "إضافة دور جديد",
        "room" => "إضافة غرفة جديدة",
        "assign" => "تسكين نزيل",
        "maintenance" => "طلب صيانة جديد",
        "complete-maintenance" => "تأكيد تنفيذ طلب الصيانة",
        _ => "إجراء"
    };

    private string PopupSubtitle => ActivePopup switch
    {
        "floor" => "أدخل بيانات الدور ثم احفظه مباشرة.",
        "room" => "حدد الدور ورقم الغرفة والسعة المتاحة.",
        "assign" => "اختر النزيل والغرفة لإنشاء سجل الإشغال.",
        "maintenance" => "سجل البلاغ وحدد الأولوية والمسؤول عن التنفيذ.",
        "complete-maintenance" => "سيتم إغلاق الطلب وتحديث لوحة الصيانة.",
        _ => string.Empty
    };

    protected override async Task OnInitializedAsync()
    {
        await Load();
        AutoRefreshCts = new CancellationTokenSource();
        _ = RefreshRoomsPeriodicallyAsync(AutoRefreshCts.Token);
    }

    public ValueTask DisposeAsync()
    {
        AutoRefreshCts?.Cancel();
        AutoRefreshCts?.Dispose();
        return ValueTask.CompletedTask;
    }

    private Task Load() => LoadWorkspaceAsync();

    private async Task LoadWorkspaceAsync(bool preserveFormState = false)
    {
        var selectedManagedRoomId = ManagedRoom.RoomId;
        Model = await RoomService.GetWorkspaceAsync(SelectedFloorId);

        if (!preserveFormState)
        {
            NewRoom.FloorId = Model.Floors.FirstOrDefault()?.Id ?? Guid.Empty;
            Assignment.RoomId = Model.RoomOptions.FirstOrDefault()?.Id ?? Guid.Empty;
            Assignment.ResidentId = Model.ResidentOptions.FirstOrDefault()?.Id ?? Guid.Empty;
            Maintenance.RoomId = Model.RoomOptions.FirstOrDefault()?.Id ?? Guid.Empty;
        }

        ManagedRoom.RoomId = Model.RoomOptions.Any(room => room.Id == selectedManagedRoomId)
            ? selectedManagedRoomId
            : Model.RoomOptions.FirstOrDefault()?.Id ?? Guid.Empty;

        if (!preserveFormState || !IsRoomManagementOpen)
        {
            SyncManagedRoomCapacity();
        }
    }

    private async Task RefreshRoomsPeriodicallyAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(3));

        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (IsBusy || IsAutoRefreshing)
                {
                    continue;
                }

                await InvokeAsync(async () =>
                {
                    IsAutoRefreshing = true;
                    try
                    {
                        await LoadWorkspaceAsync(preserveFormState: true);
                        StateHasChanged();
                    }
                    finally
                    {
                        IsAutoRefreshing = false;
                    }
                });
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void OpenPopup(string key)
    {
        ActivePopup = key;
        LastActionArea = key;
    }

    private void ClosePopup()
    {
        ActivePopup = null;
        PendingMaintenanceRequestId = null;
        PendingMaintenanceTitle = string.Empty;
    }

    private void OpenCompleteMaintenancePopup(Guid requestId, string title)
    {
        PendingMaintenanceRequestId = requestId;
        PendingMaintenanceTitle = title;
        ActivePopup = "complete-maintenance";
        LastActionArea = "maintenance";
    }

    private async Task ConfirmCompleteMaintenanceAsync()
    {
        if (PendingMaintenanceRequestId.HasValue)
        {
            await CompleteMaintenanceAsync(PendingMaintenanceRequestId.Value);
        }
    }

    private async Task CreateFloorAsync()
    {
        LastActionArea = "floor";
        await ExecuteAsync(async () =>
        {
            await CreateFloorHandler.Handle(new CreateFloorCommand(new RoomFloorCreateDto(NewFloor.Name, NewFloor.Number)), CancellationToken.None);
            NewFloor = new();
            Message = "تم حفظ الدور بنجاح.";
            ClosePopup();
        });
    }

    private async Task CreateRoomAsync()
    {
        LastActionArea = "room";
        await ExecuteAsync(async () =>
        {
            await CreateRoomHandler.Handle(new CreateRoomCommand(new RoomCreateDto(NewRoom.FloorId, NewRoom.Number, NewRoom.Capacity)), CancellationToken.None);
            NewRoom = new RoomForm { Capacity = 1, FloorId = Model?.Floors.FirstOrDefault()?.Id ?? Guid.Empty };
            Message = "تم حفظ الغرفة بنجاح.";
            ClosePopup();
        });
    }

    private async Task UpdateRoomCapacityAsync()
    {
        LastActionArea = "manage";
        await ExecuteAsync(async () =>
        {
            await UpdateRoomCapacityHandler.Handle(new UpdateRoomCapacityCommand(new RoomCapacityUpdateDto(ManagedRoom.RoomId, ManagedRoom.Capacity)), CancellationToken.None);
            Message = "تم تعديل عدد الأسرة داخل الغرفة.";
        });
    }

    private async Task DeleteRoomAsync()
    {
        LastActionArea = "manage";
        await ExecuteAsync(async () =>
        {
            await DeleteRoomHandler.Handle(new DeleteRoomCommand(ManagedRoom.RoomId), CancellationToken.None);
            ManagedRoom = new();
            IsRoomManagementOpen = false;
            Message = "تم حذف الغرفة من التشغيل مع الاحتفاظ بسجلها.";
        });
    }

    private async Task AssignResidentAsync()
    {
        LastActionArea = "assign";
        await ExecuteAsync(async () =>
        {
            await AssignResidentToRoomHandler.Handle(new AssignResidentToRoomCommand(new RoomAssignmentDto(Assignment.ResidentId, Assignment.RoomId)), CancellationToken.None);
            Message = "تم تسكين النزيل في الغرفة.";
            ClosePopup();
        });
    }

    private async Task CreateMaintenanceAsync()
    {
        LastActionArea = "maintenance";
        await ExecuteAsync(async () =>
        {
            await CreateRoomMaintenanceRequestHandler.Handle(new CreateRoomMaintenanceRequestCommand(new RoomMaintenanceCreateDto(
                Maintenance.RoomId,
                Maintenance.ResidentId,
                Maintenance.Title,
                Maintenance.Description,
                Maintenance.Priority,
                Maintenance.ReportedBy,
                Maintenance.AssignedTo)), CancellationToken.None);
            Maintenance = new MaintenanceForm { Priority = "Normal", ReportedBy = "إدارة الدار" };
            Message = "تم تسجيل طلب الصيانة.";
            ClosePopup();
        });
    }

    private async Task CompleteMaintenanceAsync(Guid requestId)
    {
        LastActionArea = "maintenance";
        await ExecuteAsync(async () =>
        {
            await CompleteRoomMaintenanceRequestHandler.Handle(new CompleteRoomMaintenanceRequestCommand(requestId, "system"), CancellationToken.None);
            Message = "تم إغلاق طلب الصيانة.";
            ClosePopup();
        });
    }

    private async Task ExecuteAsync(Func<Task> action)
    {
        if (IsBusy)
        {
            return;
        }

        try
        {
            IsBusy = true;
            MessageIsError = false;
            await action();
            await Load();
        }
        catch (ValidationException ex)
        {
            MessageIsError = true;
            Message = TranslateError(ex.Message);
        }
        catch (Exception ex)
        {
            MessageIsError = true;
            Message = TranslateError(ex.Message);
        }
        finally
        {
            IsBusy = false;
        }
    }

    private RenderFragment PanelMessage(string area) => builder =>
    {
        if (LastActionArea != area || string.IsNullOrWhiteSpace(Message))
        {
            return;
        }

        builder.OpenElement(0, "small");
        builder.AddAttribute(1, "class", $"room-inline-note {(MessageIsError ? "error" : "success")}");
        builder.AddContent(2, Message);
        builder.CloseElement();
    };

    private static int RoomFill(RoomCardDto room) =>
        room.Capacity <= 0 ? 0 : Math.Clamp((int)Math.Round(room.Occupied * 100m / room.Capacity), 0, 100);

    private bool CanDeleteManagedRoom
    {
        get
        {
            var room = FindRoom(ManagedRoom.RoomId);
            return room is not null && room.Occupied == 0 && room.MaintenanceState == "none";
        }
    }

    private void OpenRoomManagement(RoomCardDto room)
    {
        ManagedRoom.RoomId = room.Id;
        ManagedRoom.Capacity = room.Capacity;
        IsRoomManagementOpen = true;
        LastActionArea = "manage";
    }

    private void CloseRoomManagement()
    {
        IsRoomManagementOpen = false;
    }

    private void SyncManagedRoomCapacity()
    {
        var room = FindRoom(ManagedRoom.RoomId);
        ManagedRoom.Capacity = room?.Capacity ?? Math.Max(1, ManagedRoom.Capacity);
    }

    private RoomCardDto? FindRoom(Guid roomId) =>
        Model?.FloorSections.SelectMany(floor => floor.Rooms).FirstOrDefault(room => room.Id == roomId);

    private static string RoomStatusText(RoomCardDto room)
    {
        if (room.DelayedMedicationCount > 0)
        {
            return "علاج متأخر";
        }

        if (room.MaintenanceState == "urgent")
        {
            return "صيانة عاجلة";
        }

        if (room.MaintenanceState == "open")
        {
            return "تحت المتابعة";
        }

        if (room.Occupied >= room.Capacity)
        {
            return "مكتملة";
        }

        return room.Occupied == 0 ? "متاحة" : "مشغولة جزئيا";
    }

    private static string MaintenanceStateText(string state) => state switch
    {
        "urgent" => "صيانة عاجلة",
        "open" => "طلب صيانة مفتوح",
        _ => "لا توجد صيانة مفتوحة"
    };

    private static string PriorityText(string priority) => priority switch
    {
        "Low" => "منخفضة",
        "High" => "عالية",
        "Urgent" => "عاجلة",
        _ => "متوسطة"
    };

