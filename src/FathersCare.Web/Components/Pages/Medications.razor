    private sealed class ReceiveMedicineForm
    {
        public string ResidentId { get; set; } = "";
        public string? MedicineName { get; set; }
        public string? Strength { get; set; }
        public string? Form { get; set; } = "قرص";
        public decimal QuantityReceived { get; set; } = 31;
        public DateTime ReceivedOn { get; set; } = DateTime.Today;
        public DateTime? ExpiresOn { get; set; } = DateTime.Today.AddMonths(6);
        public string? ReceivedFrom { get; set; }
        public string? ReceivedBy { get; set; } = "ممرضة الدار";
        public string? PrescribedBy { get; set; }
        public string? PrescriptionReference { get; set; }
        public DateTime? PrescriptionDate { get; set; } = DateTime.Today;
        public DateTime StartsOn { get; set; } = DateTime.Today;
        public DateTime EndsOn { get; set; } = DateTime.Today.AddMonths(1).AddDays(-1);
        public string? Instructions { get; set; }
        public List<DoseFormLine> Doses { get; set; } = [];
    }

    private sealed class DoseFormLine
    {
        public string Time { get; set; } = "08:00";
        public decimal Quantity { get; set; } = 1;
        public string Timing { get; set; } = "AnyTime";
    }
}
