@inject UiText T

<div class="brand-panel sidebar-brand-ultra">
    <div class="crest">
        <img src="images/fathers-care-logo.jpg" alt="Fathers Care logo" />
    </div>
    <div class="brand-ar">دار القديس إسطفانوس<br /><span>للآباء المسنين - المعادي</span></div>
    <div class="brand-en">FATHERS CARE</div>
    <div class="brand-tagline">@T["App.Tagline"]</div>
</div>

<nav class="side-nav ultra-nav" aria-label="@T["Topbar.Menu"]">
    <div class="nav-section">
        <span class="nav-section-title">@T["Nav.Section.Core"]</span>
        <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
            <span class="nav-label">@T["Nav.Dashboard"]</span>
        </NavLink>
        <NavLink class="nav-item" href="residents">
            <span class="nav-label">@T["Nav.Residents"]</span>
        </NavLink>
        <NavLink class="nav-item" href="rooms">
            <span class="nav-label">@T["Nav.Rooms"]</span>
        </NavLink>
        <NavLink class="nav-item" href="medications">
            <span class="nav-label">@T["Nav.Medications"]</span>
        </NavLink>
        <NavLink class="nav-item" href="nutrition">
            <span class="nav-label">@T["Nav.Nutrition"]</span>
        </NavLink>
    </div>

    <div class="nav-section">
        <span class="nav-section-title">@T["Nav.Section.Care"]</span>
        <span class="nav-item disabled" role="link" aria-disabled="true">
            <span class="nav-label">@T["Nav.Healthcare"]</span>
            <span class="nav-badge">@T["Nav.ComingSoon"]</span>
        </span>
        <span class="nav-item disabled" role="link" aria-disabled="true">
            <span class="nav-label">@T["Nav.SpiritualLife"]</span>
            <span class="nav-badge">@T["Nav.ComingSoon"]</span>
        </span>
    </div>

    <div class="nav-section">
        <span class="nav-section-title">@T["Nav.Section.Admin"]</span>
        <NavLink class="nav-item" href="reports">
            <span class="nav-label">@T["Nav.Reports"]</span>
        </NavLink>
        <span class="nav-item disabled" role="link" aria-disabled="true">
            <span class="nav-label">@T["Nav.Staff"]</span>
            <span class="nav-badge">@T["Nav.ComingSoon"]</span>
        </span>
        <span class="nav-item disabled" role="link" aria-disabled="true">
            <span class="nav-label">@T["Nav.Finance"]</span>
            <span class="nav-badge">@T["Nav.ComingSoon"]</span>
        </span>
        <span class="nav-item disabled" role="link" aria-disabled="true">
            <span class="nav-label">@T["Nav.Inventory"]</span>
            <span class="nav-badge">@T["Nav.ComingSoon"]</span>
        </span>
        <span class="nav-item disabled" role="link" aria-disabled="true">
            <span class="nav-label">@T["Nav.Maintenance"]</span>
            <span class="nav-badge">@T["Nav.ComingSoon"]</span>
        </span>
        <span class="nav-item disabled" role="link" aria-disabled="true">
            <span class="nav-label">@T["Nav.Settings"]</span>
            <span class="nav-badge">@T["Nav.ComingSoon"]</span>
        </span>
    </div>
</nav>
